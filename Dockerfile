# ARG задает переменную сборки Docker.
# Эта переменная доступна на этапе сборки образа, а не во время обычного запуска контейнера.
# Здесь мы задаем версию Python по умолчанию.
# Если при docker build не передать другое значение через --build-arg py_version=..., будет использоваться Python 3.11.2.
ARG py_version=3.11.2


# FROM начинает новый этап сборки Docker-образа.
# Здесь мы берем официальный Python-образ как базу.
# python:$py_version-slim-bullseye означает:
# - python: официальный образ Python из Docker Hub;
# - $py_version: сюда подставится значение ARG py_version, то есть по умолчанию 3.11.2;
# - slim: облегченный образ, где нет многих лишних системных пакетов;
# - bullseye: Debian 11 Bullseye, то есть базовая Linux userland-среда образа.
# AS base задает имя этому этапу сборки.
# base — это не имя готового Docker image, а имя build stage внутри этого Dockerfile.
# Потом другие этапы смогут написать FROM base и унаследовать все, что мы установим здесь.
FROM python:$py_version-slim-bullseye AS base


# RUN выполняет команды внутри образа во время сборки.
# Все команды ниже будут выполнены в одном слое Docker-образа.
# Обратный слэш \ переносит длинную команду на следующую строку.
# Оператор && означает: выполнить следующую команду только если предыдущая завершилась успешно.
RUN apt-get update \
  \
  # apt-get update обновляет список доступных пакетов из Debian-репозиториев.
  # Он не устанавливает пакеты, а только обновляет локальный индекс пакетов.
  # Без этого apt-get install может не найти нужные версии пакетов.
  && apt-get install -y --no-install-recommends \
    \
    # build-essential — набор базовых инструментов для сборки программ из исходников.
    # Обычно включает компиляторы и связанные инструменты, например gcc/g++.
    # Может понадобиться, если pip будет собирать Python-пакеты из исходников.
    # Здесь версия закреплена явно: 12.9.
    build-essential=12.9 \
    \
    # ca-certificates — набор корневых SSL/TLS-сертификатов.
    # Нужен, чтобы контейнер доверял HTTPS-сайтам.
    # Без него могут ломаться скачивания с GitHub, PyPI и других HTTPS-ресурсов.
    # Здесь версия закреплена явно: 20210119.
    ca-certificates=20210119 \
    \
    # libpq-dev — development-библиотека PostgreSQL.
    # Она нужна для сборки и работы некоторых Python-пакетов, которые подключаются к PostgreSQL.
    # Например, она может понадобиться для PostgreSQL-драйверов.
    # Здесь версия закреплена явно: 13.23-0+deb11u2.
    libpq-dev=13.23-0+deb11u2 \
    \
    # make — утилита для сборки программ из исходников.
    # В этом Dockerfile она явно нужна для сборки Git из исходников.
    # build-essential часто уже подтягивает make, но здесь make закреплен отдельной версией явно.
    # Здесь версия закреплена явно: 4.3-4.1.
    make=4.3-4.1 \
    \
    # openssh-client — SSH-клиент внутри контейнера.
    # Он может понадобиться, если dbt-проект или dbt packages будут подтягиваться из приватных Git-репозиториев по SSH.
    # Например, через git@github.com:company/repo.git.
    # Здесь версия закреплена явно: 1:8.4p1-5+deb11u3.
    openssh-client=1:8.4p1-5+deb11u3 \
    \
    # software-properties-common — набор дополнительных утилит для управления apt-репозиториями.
    # В этом конкретном Dockerfile он напрямую дальше не используется.
    # Его можно оставить, если образ взят из шаблона dbt или если в будущем будут добавляться репозитории.
    # Если нужен максимально минимальный образ, этот пакет можно проверить на необходимость и, возможно, удалить.
    # Здесь версия закреплена явно: 0.96.20.2-2.1.
    software-properties-common=0.96.20.2-2.1 \
  \
  # apt-mark hold помечает пакеты как "удерживаемые".
  # Это значит, что последующие apt upgrade/dist-upgrade не должны менять их версии.
  # Здесь это нужно, потому что выше версии пакетов явно закреплены.
  && apt-mark hold \
    \
    # Удерживаем build-essential на установленной версии.
    build-essential \
    \
    # Удерживаем ca-certificates на установленной версии.
    ca-certificates \
    \
    # Удерживаем libpq-dev на установленной версии.
    libpq-dev \
    \
    # Удерживаем make на установленной версии.
    make \
    \
    # Удерживаем openssh-client на установленной версии.
    openssh-client \
    \
    # Удерживаем software-properties-common на установленной версии.
    software-properties-common \
  \
  # apt-get dist-upgrade обновляет остальные установленные пакеты базового образа.
  # Пакеты, которые выше поставлены на hold, обновляться не должны.
  # Идея: закрепленные пакеты остаются нужных версий, а остальные пакеты получают обновления безопасности.
  && apt-get dist-upgrade -y \
  \
  # Ниже устанавливаются временные зависимости для сборки Git из исходников.
  # Они нужны только во время сборки образа.
  # После установки Git эти пакеты будут удалены, чтобы итоговый образ был меньше.
  && apt-get install -y --no-install-recommends \
    \
    # wget — утилита для скачивания файлов по HTTP/HTTPS.
    # Здесь она нужна, чтобы скачать архив с исходным кодом Git.
    wget \
    \
    # libcurl4-gnutls-dev — development-библиотека curl.
    # Она нужна при сборке Git, чтобы Git поддерживал работу по HTTP/HTTPS.
    libcurl4-gnutls-dev \
    \
    # libexpat1-dev — development-библиотека XML-парсера Expat.
    # Она используется некоторыми компонентами Git при сборке.
    libexpat1-dev \
    \
    # libssl-dev — development-библиотека OpenSSL.
    # Нужна для поддержки SSL/TLS при сборке программ, включая Git.
    libssl-dev \
    \
    # zlib1g-dev — development-библиотека zlib.
    # Нужна для поддержки сжатия данных.
    # Git использует сжатие для объектов репозитория.
    zlib1g-dev \
  \
  # Скачиваем архив исходного кода Git версии 2.50.1 с GitHub.
  # Это делается, чтобы получить конкретную версию Git, а не ту, которая доступна в apt-репозитории Debian.
  && wget https://github.com/git/git/archive/refs/tags/v2.50.1.tar.gz \
  \
  # Распаковываем скачанный архив.
  # После распаковки появится директория git-2.50.1.
  && tar -xf v2.50.1.tar.gz \
  \
  # Переходим в директорию с исходным кодом Git.
  # Следующие команды make будут выполняться уже внутри этой директории.
  && cd git-2.50.1 \
  \
  # Собираем Git из исходного кода.
  # prefix=/usr/local означает, что установленный Git попадет в /usr/local/bin/git.
  # NO_TCLTK=1 отключает сборку GUI-компонентов Git, например gitk.
  # NO_GETTEXT=1 отключает поддержку gettext-переводов, чтобы упростить сборку.
  # all означает собрать основную программу и необходимые компоненты.
  && make prefix=/usr/local NO_TCLTK=1 NO_GETTEXT=1 all \
  \
  # Устанавливаем собранный Git внутрь файловой системы образа.
  # После этой команды git будет доступен внутри контейнера.
  && make prefix=/usr/local NO_TCLTK=1 NO_GETTEXT=1 install \
  \
  # Возвращаемся на уровень выше из директории git-2.50.1.
  # Это нужно, чтобы затем удалить папку с исходниками.
  && cd .. \
  \
  # Удаляем директорию с исходниками Git и скачанный архив.
  # Они больше не нужны после установки Git.
  # Это уменьшает размер итогового Docker-образа.
  && rm -rf git-2.50.1 v2.50.1.tar.gz \
  \
  # Удаляем временные development-зависимости, которые использовались только для сборки Git.
  # Установленный Git при этом остается, потому что он был установлен в /usr/local.
  && apt-get remove -y \
    \
    # Удаляем development-библиотеку curl.
    libcurl4-gnutls-dev \
    \
    # Удаляем development-библиотеку Expat.
    libexpat1-dev \
    \
    # Удаляем development-библиотеку OpenSSL.
    libssl-dev \
    \
    # Удаляем wget, потому что после скачивания Git он больше не нужен.
    wget \
    \
    # Удаляем development-библиотеку zlib.
    zlib1g-dev \
  \
  # apt-get autoremove удаляет пакеты, которые были установлены автоматически как зависимости,
  # но больше не нужны после удаления временных development-пакетов.
  && apt-get autoremove -y \
  \
  # apt-get clean очищает локальный кэш apt.
  # Это уменьшает размер Docker-образа.
  && apt-get clean \
  \
  # rm -rf удаляет временные файлы и списки пакетов apt.
  # /var/lib/apt/lists/* — локальные списки пакетов после apt-get update.
  # /tmp/* — временные файлы.
  # /var/tmp/* — еще одна директория для временных файлов.
  # Это стандартная практика для уменьшения размера Docker-образа.
  && rm -rf \
    /var/lib/apt/lists/* \
    /tmp/* \
    /var/tmp/*


# ENV задает переменную окружения внутри итогового образа.
# PYTHONIOENCODING=utf-8 говорит Python использовать UTF-8 для стандартного ввода/вывода.
# Это помогает избежать проблем с кириллицей и другими Unicode-символами в логах dbt.
ENV PYTHONIOENCODING=utf-8


# ENV задает еще одну переменную окружения внутри образа.
# LANG=C.UTF-8 задает базовую UTF-8 локаль.
# Это помогает системным утилитам и Python корректнее работать со строками и кодировками.
ENV LANG=C.UTF-8


# RUN выполняет команду обновления Python-инструментов установки пакетов.
# python -m pip означает: запусти pip как модуль текущего Python.
# --upgrade означает: обнови указанные пакеты до заданных версий.
# pip — менеджер Python-пакетов.
# setuptools — инструмент для сборки и установки Python-пакетов.
# wheel — инструмент для работы с готовыми собранными Python-пакетами формата .whl.
# Версии закреплены, чтобы сборка была более воспроизводимой.
# --no-cache-dir запрещает pip сохранять кэш скачанных пакетов внутри образа.
RUN python -m pip install --upgrade "pip==24.0" "setuptools==69.2.0" "wheel==0.43.0" --no-cache-dir


# FROM начинает новый этап сборки.
# Этот этап называется dbt.
# Он наследуется от stage base, то есть получает:
# - Python;
# - pip;
# - системные зависимости;
# - собранный Git;
# - переменные окружения PYTHONIOENCODING и LANG.
# Важно: dbt здесь — это имя build stage внутри Dockerfile, а не имя готового Docker image.
# Имя готового image задается отдельно при docker build через -t, например: -t my-dbt.
FROM base AS dbt


# RUN устанавливает Python-пакеты внутрь stage dbt.
# Здесь устанавливается сам dbt-core и два адаптера:
# - dbt-postgres для PostgreSQL;
# - dbt-clickhouse для ClickHouse.
# --no-cache-dir запрещает pip сохранять кэш пакетов, чтобы образ был меньше.
RUN python -m pip install --no-cache-dir \
    \
    # dbt-core — ядро dbt.
    # Оно умеет читать dbt_project.yml, строить DAG моделей, компилировать Jinja+SQL и запускать команды dbt.
    "dbt-core" \
    \
    # dbt-postgres — адаптер dbt для PostgreSQL.
    # Он добавляет поддержку подключения к PostgreSQL и выполнения SQL-моделей в PostgreSQL.
    "dbt-postgres" \
    \
    # dbt-clickhouse — адаптер dbt для ClickHouse.
    # Он добавляет поддержку подключения к ClickHouse и выполнения dbt-моделей в ClickHouse.
    "dbt-clickhouse"


# HEALTHCHECK задает команду проверки "здоровья" контейнера.
# Docker сможет запускать эту команду, чтобы понять, что dbt внутри контейнера доступен.
# dbt --version проверяет, что команда dbt установлена и может стартовать.
# || exit 1 означает: если dbt --version завершился ошибкой, вернуть код ошибки 1.
# Для одноразового dbt-runner-контейнера healthcheck не всегда обязателен, но он полезен как быстрая проверка образа.
HEALTHCHECK CMD dbt --version || exit 1


# WORKDIR задает рабочую директорию внутри контейнера.
# Если директории /usr/app/dbt/ нет, Docker создаст ее.
# Когда контейнер запустится, текущей директорией будет /usr/app/dbt/.
# Обычно сюда монтируют папку с dbt-проектом, где лежит dbt_project.yml.
WORKDIR /usr/app/dbt/


# ENTRYPOINT задает основную команду контейнера.
# Здесь основной командой будет dbt.
# Все аргументы после имени образа в docker run будут добавлены к dbt.
# Например:
# docker run --rm my-dbt debug
# превратится внутри контейнера в:
# dbt debug.
ENTRYPOINT ["dbt"]

# билдить образ будем командой: docker build --target dbt -t my-dbt .
# тут --target dbt  показывает , что из докер файла надо взять стейдж под названием dbt, а не base. 
# И в итоге образ будет с уже установленным dbt, а не просто с Python и Git.
# -t my-dbt задает имя готового образа, который мы будем использовать для запуска контейнеров.